# Database (Supabase Postgres or local Postgres)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/meetmind

# JWT
JWT_SECRET=change-me-to-a-real-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Azure AD / Microsoft Graph (for Teams bot — live meeting attendance)
AZURE_APP_ID=
AZURE_APP_PASSWORD=
AZURE_TENANT_ID=
GRAPH_API_SCOPE=https://graph.microsoft.com/.default

# Bot Framework
BOT_FRAMEWORK_ENDPOINT=https://your-bot.azurewebsites.net/api/messages

# LLM — Groq for AI-powered meeting summaries + extraction + chat
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Cognee Cloud — memory layer for per-user isolated meeting context
# Get your key at https://platform.cognee.ai/ → API Keys
COGNEE_API_KEY=
COGNEE_BASE_URL=https://api.cognee.ai

# App
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
